trad.ord.4.fl.inv=ifnull(dispo,'A')
trad.ord.5.fl.inv=0+split(ifnull(tr_vals,'0#0#0'),'#',2)
trad.ord.6.fl.inv=0+split(ifnull(tr_vals,'0#0#0'),'#',1)
trad.ord.7.fl.inv=if(split(ifnull(tr_vals,'0#0#0'),'#',1)='0',0,(0+split(ifnull(tr_vals,'0#0#0'),'#',2))/(0+split(ifnull(tr_vals,'0#0#0'),'#',1)))
trad.ord.8.fl.inv=if(fl_traduttore='S',9999-num_nomatch,9999)
trad.ord.9.fl.inv=if(fl_traduttore='S',9999-num_fuzzy,9999)
trad.ord.10.fl.inv=if(fl_traduttore='S',9999-num_repeat,9999)
