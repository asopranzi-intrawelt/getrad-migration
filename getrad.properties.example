trad.ord.17.id=11768798033778
trad.ord.17.fl=(100/(0+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',1)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',2)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',3)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',4)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',5))) DESC
trad.ord.18.id=11768798033779
trad.ord.18.fl=(CASE WHEN Split(ds_sw, '@',4) LIKE '%2009%'THEN 1 ELSE 0  END) DESC
trad.ord.19.id=11768798033780
trad.ord.19.fl=(CASE WHEN Split(ds_sw, '@',4) LIKE '%2011%'THEN 1 ELSE 0  END) DESC
trad.ord.20.id=11768798033781
trad.ord.20.fl=(0+substrCount(Split(ds_sw, '@',2),'#')+substrCount(Split(ds_sw, '@',3),'#')+ (CASE WHEN Split(ds_sw, '@',4) LIKE '%2006%'THEN 1 ELSE 0  END)) DESC
trad.ord.21.id=91726763780403
trad.ord.21.fl=(CASE WHEN Split(ds_sw, '@',4) LIKE '%2007%'THEN 1 ELSE 0  END) DESC
trad.ord.22.id=91726763780438
trad.ord.22.fl=lavori_aperti DESC
trad.ord.1.fl.inv=if(fl_traduttore='S',1,0)
trad.ord.2.fl.inv=if(fl_revisore='S',1,0)
