trad.ord.12.fl.inv=0+if(fl_traduttore='S',9999999-tot_tr,9999999)
trad.ord.13.fl.inv=0+if(fl_revisore='S',9999999-tot_rv,9999999)
trad.ord.14.fl.inv=fl_cliente
trad.ord.15.fl.inv=fl_sett, fl_sett_micro
trad.ord.16.fl.inv=0+if(ds_tmz='#',99,99-ds_tmz)
trad.ord.17.fl.inv=(100/(0+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',1)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',2)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',3)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',4)+split(IFNULL(lista_revisioni,'0#0#0#0#0'),'#',5))) ASC
trad.ord.18.fl.inv=(CASE WHEN Split(ds_sw, '@',4) LIKE '%2009%'THEN 1 ELSE 0  END)
