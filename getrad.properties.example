############### Parametri invio mail
mail.host=smtp.office365.com
mail.mailer=Intrawelt Mailer
##porta SMTP e protocollo di autenticazione usato dal SMTP server
mail.port=587
mail.security=TLS
# Invio mail con successo
mail.ret=Mail inviata correttamente.
# Autenticazione richiesta dal mail host (1=Si,0=No)
mail.autentication=1
# Parametri per l'autenticazione
mail.user=egetrad@intrawelt.com
mail.password=__SET_ME__
# Invio attraverso proxy
mail.proxy=
mail.pport=
# Soggetto di default
mail.subject=Richiesta Informazioni
mail.from=egetrad@intrawelt.com
mail.preventivi.bcc=preventivi@intrawelt.com
mail.batch.bcc=egetrad@intrawelt.com
mail.bcc.cambiopw=egetrad@intrawelt.com
mail.trad.pm.from.options=egetrad@intrawelt.com;info@intrawelt.com;bandi@intrawelt.com
mail.versamenti=versamenti@intrawelt.com
mail.recruitment=recruitment@intrawelt.com
mail.accounts=accounts@intrawelt.com

############### Parametri Home Page PM
# default per il filtro job T,R,A
pm.f_job.def=111
# default per l'ordinamento
pm.sort.def=12017040468046
pm.sort.def_gr=PRJ
pm.sort.def_ord=order by 0+cd_cliente, ds_lingua_da, ds_lingua_a, id_incarico_tr

############### Parametri Dashboard Trad
# default per il filtro job T,R,A
trad.f_job.def=111
# default per l'ordinamento
trad.sort.def=12017040468049
trad.sort.def_gr=PRJ
trad.sort.def_ord=order by right(id_incarico_tr,2) DESC, (0+id_incarico_tr) DESC

################ Contabilita'
# scadenza fattura traduttore in giorni
cont.scadenza_tr=60
cont.scadenza_tr.gg_mese=13
cont.carica_fatt=http://egetrad.intrawelt.com:8080/getrad/CaricaFatt?s=
# 1024KB
cont.upload.MaxRequestSize=1048576
cont.upload.RepositoryPath=/usr/skn/getrad/files/fatture/traduttori/
# Url fatture
cont.urlBase=http://egetrad.intrawelt.com:8080/getrad/files/fatture/traduttori/
cont.urlBase_int=http://127.0.0.1:8080/getrad/files/fatture/traduttori/
cont.urlFatt=http://egetrad.intrawelt.com:8080/getrad/jsp/fatture/index.jsp
cont.pathFatt=/files/fatture/traduttori/
# numero giorni per invio sollecito (lavorativi)
cont.scostamento=3
# numero giorni per invio notifica (lavorativi)
cont.scostamento_cl=3
# Limite in euro per la creazione fattura
cont.soglia=40
# job invio solleciti Tr
cont.job_tr.enabled=S
# job invio notifiche Cl
cont.job_cl.enabled=S
# job controllo ordini preventivi
cont.job_ord.enabled=S
# occhio che sia di mattina, perché se è PM può avere problemi
cont.job.ora_inizio=0100
# limite inferiore per accorpamento job
cont.job.limite=20100101
# ultima fattura emessa da utilizzare solo allo startup quando il db è ovviamente vuoto..
cont.last.numero=2008001880
cont.last.data=20081127
# Cartella fatture clienti
cont.base_fatt_c=/usr/skn/getrad/files/fatture/clienti/
cont.urlBase_int_c=http://127.0.0.1:8080/getrad/files/fatture/clienti/
# Profilo iva per le spese (esenti art 15)
cont.spese=5
# Profilo iva per le spese dei clienti comunitari (esenti art 7 ter)
cont.spese_comunitario=8
# Email per comunicazioni banca
cont.banca.email=marco.vitellozzi@bper.it
# primo limite per il ritardo pagamento
cont.insoluto.1=3
# secondo limite per invio email
cont.insoluto.2=6
# terzo limite per la proroga
cont.insoluto.3=15
# limite in giorni per la modifica di una disposizione ridi
cont.max.ridi.days=3
# giorno oltre il quale le fatture non emesse del mese precedente compaiono nel mese corrente (e spariscono dal mese scorso)
cont.giorno.scatto.fatture=16
# percorso foglio di stile per fatturePA
cont.fatturaPA.xsl=/usr/skn/getrad/WEB-INF/xsl/fatturapa_v1.2.1.xsl
# id dei servizi da far uscire nella lista asseverazioni/certificazioni sulla HomePM
