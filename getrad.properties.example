################ Parametri per il logging dell'applicazione
log4j.logger.ApplicationLogger=INFO, APP, MAIL
log4j.appender.APP=org.apache.log4j.RollingFileAppender
log4j.appender.APP.File=/usr/skn/getrad/WEB-INF/logs/Application.log
log4j.appender.APP.MaxFileSize=10000KB
log4j.appender.APP.MaxBackupIndex=10
log4j.appender.APP.layout=org.apache.log4j.PatternLayout
# Print the date in ISO 8601 format
log4j.appender.APP.layout.ConversionPattern=%d [%t] %-5p %c - %m%n
# Encoding per log4j..
# log4j.appender.APP.Encoding=UTF-8

################ Parametri per il logging degli accessi (formato csv)
log4j.logger.AccessLogger=DEBUG, ACC
log4j.appender.ACC=org.apache.log4j.RollingFileAppender
log4j.appender.ACC.File=/usr/skn/getrad/WEB-INF/logs/Accesses.csv
log4j.appender.ACC.MaxFileSize=100000KB
log4j.appender.ACC.MaxBackupIndex=10
log4j.appender.ACC.layout=org.apache.log4j.PatternLayout
# Print the date in ISO 8601 format
log4j.appender.ACC.layout.ConversionPattern=%d [%t] ; %-5p ; %m%n

################ Parametri per il logging tramite mail dei soli errori
# The number of logging events delivered in this e-mail depend on the value of BufferSize option.
# The SMTPAppender keeps only the last BufferSize logging events in its cyclic buffer.
# This keeps memory requirements at a reasonable level while still delivering useful application context.
# By default, an email message will be sent when an ERROR or higher severity message is appended.
log4j.appender.MAIL=skn.util.logger.FilteredSMTPAppender
# il numero di eventi inviati nell'email dipende da questo parametro
log4j.appender.MAIL.BufferSize=1
# debug mail session su stdout
log4j.appender.MAIL.SMTPDebug=false
log4j.appender.MAIL.SMTPHost=smtp.office365.com
# se il server non richiede autenticazione commentare queste due
log4j.appender.MAIL.SMTPUsername=egetrad@intrawelt.com
log4j.appender.MAIL.SMTPPassword=__SET_ME__
log4j.appender.MAIL.From=egetrad@intrawelt.com
log4j.appender.MAIL.Subject=Monitor Errori
# lista dei destinatari (separati da virgola se multipli)
log4j.appender.MAIL.To=egetrad@intrawelt.com
log4j.appender.MAIL.cc=
log4j.appender.MAIL.bcc=
#
log4j.appender.MAIL.layout=org.apache.log4j.PatternLayout
#log4j.appender.MAIL.layout.ConversionPattern=%d [%t] %-5p %c %x - %m%n
log4j.appender.MAIL.layout.ConversionPattern=%p %t %c.%m%n
#parametri aggiuntivi per il FilteredSMTPAppender, numero massimo di mail nel timeframe, se c'è bisogno del TLS
log4j.appender.MAIL.TimeFrame=30
log4j.appender.MAIL.MaxEMails=10
log4j.appender.MAIL.TLS=true

################ Parametri del Database Connection Pool
