############### se 0 disattiva il rilascio forzato della risorsa.
util.ConnectionManager.MaxCheckoutSeconds=0
util.ConnectionManager.LogFile=/usr/skn/getrad/WEB-INF/logs/ConnectionManager.log
util.ConnectionManager.TestQuery=select count\(*\) from an_utenti
util.ConnectionManager.logAppend=N
##############0 nulla, 1 error, 2 warn, info
util.ConnectionManager.debugLevel=2

